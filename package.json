{
  "name": "Spotter",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "dev": "tsx --watch scripts/dev-server.ts",
    "commands:register": "tsx scripts/register-commands.ts",
    "infra:synth:dev": "cd infra && npx cdk synth -c env=dev",
    "infra:synth:prod": "cd infra && npx cdk synth -c env=prod",
    "infra:diff:dev": "cd infra && npx cdk diff -c env=dev",
    "infra:diff:prod": "cd infra && npx cdk diff -c env=prod",
    "infra:deploy:dev": "cd infra && npx cdk deploy -c env=dev",
    "infra:deploy:prod": "cd infra && npx cdk deploy -c env=prod"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1009.0",
    "@aws-sdk/lib-dynamodb": "^3.1009.0",
    "@discordjs/builders": "^1.13.1",
    "@discordjs/rest": "^2.6.0",
    "discord-api-types": "^0.38.42",
    "discord-interactions": "^4.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@types/aws-lambda": "^8.10.161",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "esbuild": "^0.25.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.5",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
